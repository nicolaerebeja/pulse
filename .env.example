# Database
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://pulse:changeme@postgres:5432/pulse

# Telegram
TELEGRAM_BOT_TOKEN=

# YouTube Data API v3
YOUTUBE_API_KEY=

